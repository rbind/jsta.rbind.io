  title = {Applying the Patch-Matrix Model to Lakes: A Connectivity-Based Conservation Framework},
  shorttitle = {Applying the Patch-Matrix Model to Lakes},
  author = {McCullough, Ian M. and King, Katelyn B. S. and Stachelek, Joseph and Diaz, Jessica and Soranno, Patricia A. and Cheruvelil, Kendra Spence},
